<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Amperage Labs</title>
<meta name="description" content="Amperage Labs builds precise, formula-transparent engineering tools for electrical and electronics work. Free tools for off-grid solar sizing, battery management, and more." />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #fafafa;
    --bg-card:   #ffffff;
    --bg-input:  #f5f5f5;
    --border:    #ebebeb;
    --border-md: #e0e0e0;
    --border-lg: #d4d4d4;
    --text-pri:  #171717;
    --text-sec:  #4d4d4d;
    --text-mut:  #a3a3a3;
    --accent:    #0070f3;
    --teal:      #0099a8;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  :root.dark {
    --bg:        #0a0a0a;
    --bg-card:   #111111;
    --bg-input:  #1a1a1a;
    --border:    #222222;
    --border-md: #2a2a2a;
    --border-lg: #333333;
    --text-pri:  #ffffff;
    --text-sec:  #888888;
    --text-mut:  #444444;
    --accent:    #0070f3;
    --teal:      #00dfd8;
  }

html { 
    scroll-behavior: smooth; 
    background: var(--bg); /* Added here so the base window handles the theme switch */
  }

#bg-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: -1; /* Change from 0 to -1 */
    pointer-events: none;
    opacity: 0.6; /* Bumped up slightly for better visibility on light mode */
    transition: opacity 0.3s;
  }

  :root.dark #bg-canvas { opacity: 0.6; }

body {
    position: relative;
    /* Remove z-index: 1 entirely */
    background: transparent; /* Change from var(--bg) to transparent */
    color: var(--text-pri);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    overflow-x: hidden;
    transition: background 0.3s, color 0.3s;
  }

  /* ── NAVBAR ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    background: rgba(250,250,250,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: background 0.3s, border-color 0.3s;
  }

  :root.dark nav { background: rgba(10,10,10,0.85); }

  .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }

  .nav-mark {
    width: 28px; height: 28px;
    background: var(--text-pri);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s;
  }

  .nav-mark span {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 14px;
    color: var(--bg);
    line-height: 1;
    transition: color 0.3s;
  }

  .nav-name { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; color: var(--text-pri); }

  .nav-links { display: flex; align-items: center; gap: 6px; }

  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-sec);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    cursor: pointer;
  }

  .nav-links a:hover { color: var(--text-pri); background: rgba(128,128,128,0.08); }
  .nav-links a.active { color: var(--text-pri); background: rgba(128,128,128,0.08); }

  /* ── HERO ── */
  .hero { max-width: 960px; margin: 0 auto; padding: 100px 32px 80px; position: relative; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-sec);
    margin-bottom: 28px;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--teal);
    flex-shrink: 0;
  }

  .hero h1 {
    font-size: clamp(38px, 6vw, 62px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.06;
    color: var(--text-pri);
    margin-bottom: 24px;
    max-width: 820px;
  }

  .hero h1 em {
    font-style: normal;
    background: linear-gradient(90deg, var(--teal), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-sub {
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--text-sec);
    max-width: 540px;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 42px;
    padding: 0 20px;
    background: var(--text-pri);
    color: var(--bg);
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    border: none;
    letter-spacing: -0.01em;
    transition: opacity 0.15s, transform 0.1s;
    cursor: pointer;
    font-family: var(--font-sans);
  }

  .hero-cta:hover { opacity: 0.85; transform: translateY(-1px); }
  .hero-cta svg { flex-shrink: 0; }

  /* ── DIVIDER ── */
  .section-divider { max-width: 960px; margin: 0 auto; padding: 0 32px; border-top: 1px solid var(--border); position: relative; }

  /* ── TOOLS SECTION ── */
  .tools-section { max-width: 960px; margin: 0 auto; padding: 64px 32px 80px; position: relative; }
  .section-header { margin-bottom: 40px; }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-mut);
    margin-bottom: 12px;
  }

  .section-title { font-size: 24px; font-weight: 600; letter-spacing: -0.025em; color: var(--text-pri); }

  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }

  /* ── TOOL CARD ── */
  .tool-card {
    position: relative;
    border: 1px solid var(--border-md);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-card);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    min-height: 240px;
  }

  .tool-card:hover {
    border-color: #3a3a3a;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  :root.dark .tool-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.4); }

  .tool-card-bg {
    position: absolute;
    inset: 0;
    opacity: 0.07;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.4) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.4) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .tool-card-glow {
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,153,168,0.12), transparent 70%);
    pointer-events: none;
  }

  :root.dark .tool-card-glow { background: radial-gradient(circle, rgba(0,223,216,0.18), transparent 70%); }

  .tool-card-inner { position: relative; z-index: 1; padding: 24px; display: flex; flex-direction: column; gap: 14px; flex-grow: 1; }
  .tool-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }

  .tool-icon {
    width: 40px; height: 40px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border-lg);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .tool-badge-live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #22c55e;
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.2);
    border-radius: 9999px;
    padding: 4px 10px;
  }

  .tool-badge-live::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .tool-card-title { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; color: var(--text-pri); line-height: 1.3; }
  .tool-card-desc { font-size: 13px; line-height: 1.6; color: var(--text-sec); }

  .tool-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .tool-tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .tool-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--text-mut);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
    letter-spacing: 0.03em;
  }

  .tool-arrow { color: var(--text-mut); transition: color 0.15s, transform 0.15s; flex-shrink: 0; }
  .tool-card:hover .tool-arrow { color: var(--text-pri); transform: translate(2px, -2px); }

  /* ── ABOUT SECTION ── */
  .about-section { max-width: 960px; margin: 0 auto; padding: 64px 32px 80px; position: relative; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }

  .about-text h2 { font-size: 24px; font-weight: 600; letter-spacing: -0.025em; color: var(--text-pri); margin-bottom: 16px; line-height: 1.3; }
  .about-text p { font-size: 14px; line-height: 1.75; color: var(--text-sec); margin-bottom: 14px; }

  .about-principles { display: flex; flex-direction: column; gap: 16px; }

  .principle {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
    background: var(--bg-card);
    transition: background 0.3s, border-color 0.3s;
  }

  .principle-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-pri);
    margin-bottom: 6px;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .principle-title::before {
    content: '';
    width: 3px; height: 14px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .principle p { font-size: 13px; line-height: 1.65; color: var(--text-sec); }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 32px;
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
  }

  .footer-top { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .footer-brand { display: flex; align-items: center; gap: 10px; }
  .footer-name { font-size: 13px; font-weight: 600; color: var(--text-pri); }
  .footer-copy { font-size: 12px; color: var(--text-mut); }

  .footer-status { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; }
  .footer-status span { font-family: var(--font-mono); font-size: 10px; color: var(--text-mut); letter-spacing: 0.05em; }

  .footer-status .live { color: #22c55e; display: flex; align-items: center; gap: 5px; }
  .footer-status .live::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s infinite;
  }

  /* ── THEME TOGGLE ── */
  .theme-toggle {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-input);
    color: var(--text-sec);
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .theme-toggle:hover { color: var(--text-pri); background: var(--border); }
  .theme-toggle svg { pointer-events: none; }
  .icon-sun  { display: none; }
  .icon-moon { display: block; }
  :root.dark .icon-sun  { display: block; }
  :root.dark .icon-moon { display: none; }

  /* ── FOUNDER STRIP ── */
  .founder-strip {
    max-width: 960px;
    margin: 0 auto;
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-top: 1px solid var(--border);
    position: relative;
  }

  .founder-text { font-size: 12px; color: var(--text-mut); font-family: var(--font-mono); letter-spacing: 0.02em; }

  .founder-linkedin {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 6px;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  .founder-linkedin:hover { opacity: 1; transform: translateY(-1px); }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  .reveal-stagger > * {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal-stagger.visible > *:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  .reveal-stagger.visible > *:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .reveal-stagger.visible > *:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.2s; }
  .reveal-stagger.visible > *:nth-child(4) { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    nav { padding: 0 20px; }
    .hero { padding: 64px 20px 60px; }
    .tools-section, .about-section { padding: 48px 20px 60px; }
    footer { padding: 32px 20px; }
    .about-grid { grid-template-columns: 1fr; }
    .nav-links a { padding: 6px 8px; font-size: 12px; }
    .founder-strip { padding: 20px; }
  }

  @media (max-width: 480px) {
    .tools-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 34px; }
  }
</style>
</head>

<body>

  <canvas id="bg-canvas"></canvas>

  <nav>
    <a href="/" class="nav-brand">
      <div class="nav-mark"><span>A</span></div>
      <span class="nav-name">Amperage Labs</span>
    </a>
    <div class="nav-links">
      <a class="nav-anchor" data-target="tools">Tools</a>
      <a class="nav-anchor" data-target="about">About</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="Switch to dark mode">
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-eyebrow reveal">Tools &amp; Utilities</div>
    <h1 class="reveal">Built to make<br><em>technical work</em><br>more transparent.</h1>
    <p class="hero-sub reveal">Each tool here shows its reasoning openly — formulas, assumptions, and scope — so the output can be understood, not just used.</p>
    <button class="hero-cta reveal" id="hero-cta-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      Explore tools
    </button>
  </section>

  <div class="section-divider"></div>

  <!-- TOOLS -->
  <section class="tools-section" id="tools">
    <div class="section-header reveal">
      <div class="section-label">Tools</div>
      <h2 class="section-title">Available now</h2>
    </div>

    <div class="tools-grid reveal-stagger">

      <a href="/offgrid-calculator" class="tool-card">
        <div class="tool-card-bg"></div>
        <div class="tool-card-glow"></div>
        <div class="tool-card-inner">
          <div class="tool-card-top">
            <div class="tool-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00dfd8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
              </svg>
            </div>
            <span class="tool-badge-live">Live</span>
          </div>
          <div>
            <div class="tool-card-title">Off-Grid Solar, Battery &amp; MPPT Sizing Calculator</div>
          </div>
          <div class="tool-card-desc">Size your battery bank, solar array, and MPPT charge controller. Every output is traceable to a named formula.</div>
          <div class="tool-card-footer">
            <div class="tool-tags">
              <span class="tool-tag">Solar</span>
              <span class="tool-tag">BMS</span>
              <span class="tool-tag">MPPT</span>
            </div>
            <svg class="tool-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </div>
        </div>
      </a>

    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ABOUT -->
  <section class="about-section" id="about">
    <div class="about-grid">
      <div class="about-text reveal">
        <h2>Built for people who want to understand what a tool is actually doing.</h2>
        <p>Amperage Labs started from a straightforward idea: tools should show their work. Not as a feature, but as a baseline — because understanding a result is as useful as getting one.</p>
        <p>Every tool here documents its logic, states its assumptions, and is upfront about where its scope ends. The goal is to support good decisions, not to replace the judgement behind them.</p>
      </div>
      <div class="about-principles reveal-stagger">
        <div class="principle">
          <div class="principle-title">Open reasoning</div>
          <p>Every output is traceable to the logic behind it, with assumptions documented. Nothing is hidden behind a "calculate" button.</p>
        </div>
        <div class="principle">
          <div class="principle-title">Honest scope</div>
          <p>Each tool explicitly states what it does not account for. Overselling accuracy is worse than useful precision.</p>
        </div>
        <div class="principle">
          <div class="principle-title">No sign-up, no paywall</div>
          <p>Core tools are free. Shareable configuration links, no accounts required, no data collected.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOUNDER STRIP -->
  <div class="founder-strip reveal">
    <span class="founder-text">Developed By: Sourav Karmokar</span>
    <a
      href="https://www.linkedin.com/in/sourav-karmokar-722563281"
      target="_blank"
      rel="noopener noreferrer"
      class="founder-linkedin"
      aria-label="Sourav Karmokar on LinkedIn"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect width="24" height="24" rx="4" fill="#0A66C2"/>
        <path d="M7.5 9.5H5V19H7.5V9.5Z" fill="white"/>
        <circle cx="6.25" cy="6.75" r="1.5" fill="white"/>
        <path d="M19 19H16.5V14.25C16.5 13.01 15.74 12.25 14.75 12.25C13.76 12.25 13 13.01 13 14.25V19H10.5V9.5H13V10.75C13.6 9.9 14.6 9.25 15.75 9.25C17.75 9.25 19 10.75 19 13V19Z" fill="white"/>
      </svg>
    </a>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-brand">
        <div class="nav-mark"><span>A</span></div>
        <span class="footer-name">Amperage Labs.</span>
        <span class="footer-copy">© 2026. All rights reserved.</span>
      </div>
      <div class="footer-status">
        <span>TOOLS &amp; UTILITIES</span>
        <span class="live">1 TOOL LIVE</span>
      </div>
    </div>
  </footer>

<script>
  // ── AMBIENT BACKGROUND: drifting node network ──
  (function() {
    const canvas = document.getElementById('bg-canvas');
    const ctx = canvas.getContext('2d');
    let nodes = [];
    let w, h;
    const NODE_COUNT_DENSITY = 9000;
    const MAX_LINK_DIST = 160;
    const SPEED = 0.12;

    function isDark() { return document.documentElement.classList.contains('dark'); }

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = Math.max(window.innerHeight, document.body.scrollHeight);
      const count = Math.max(18, Math.min(60, Math.floor((w * window.innerHeight) / NODE_COUNT_DENSITY)));
      nodes = [];
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: Math.random() * w,
          y: Math.random() * window.innerHeight,
          vx: (Math.random() - 0.5) * SPEED,
          vy: (Math.random() - 0.5) * SPEED,
          r: Math.random() * 1.4 + 0.6
        });
      }
    }

    function step() {
      ctx.clearRect(0, 0, w, h);
      const dotColor = isDark() ? 'rgba(0,223,216,0.55)' : 'rgba(30,41,59,0.5)';
      const lineColorBase = isDark() ? '0,223,216' : '30,41,59';
      const viewTop = window.scrollY;

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > w) n.vx *= -1;
        if (n.y < 0 || n.y > window.innerHeight) n.vy *= -1;
        n.x = Math.max(0, Math.min(w, n.x));
        n.y = Math.max(0, Math.min(window.innerHeight, n.y));
      }

      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = a.x - b.x, dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MAX_LINK_DIST) {
            const alpha = (1 - dist / MAX_LINK_DIST) * 0.18;
            ctx.strokeStyle = `rgba(${lineColorBase},${alpha})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y + viewTop);
            ctx.lineTo(b.x, b.y + viewTop);
            ctx.stroke();
          }
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        ctx.beginPath();
        ctx.arc(n.x, n.y + viewTop, n.r, 0, Math.PI * 2);
        ctx.fillStyle = dotColor;
        ctx.fill();
      }

      requestAnimationFrame(step);
    }

    resize();
    window.addEventListener('resize', resize);
    window.addEventListener('load', resize);
    requestAnimationFrame(step);
  })();
</script>

<script>
  (function() {
    const saved = localStorage.getItem('al-theme');
    if (saved === 'dark') document.documentElement.classList.add('dark');
  })();

  document.addEventListener('DOMContentLoaded', () => {

    // theme toggle
    const toggleBtn = document.getElementById('theme-toggle');
    function updateToggleLabel() {
      const isDark = document.documentElement.classList.contains('dark');
      toggleBtn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }
    toggleBtn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('al-theme', isDark ? 'dark' : 'light');
      updateToggleLabel();
    });
    updateToggleLabel();

    // hash-free smooth scroll — no #tools / #about ever written to the URL
    function scrollToSection(id) {
      const target = document.getElementById(id);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    document.querySelectorAll('.nav-anchor').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        scrollToSection(el.getAttribute('data-target'));
      });
    });
    document.getElementById('hero-cta-btn').addEventListener('click', () => scrollToSection('tools'));

    // strip any leftover hash from a previous visit/share link
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }

    // scroll reveal — replays every time, both directions
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        entry.target.classList.toggle('visible', entry.isIntersecting);
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => revealObserver.observe(el));

    // active nav highlight while scrolling
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-anchor');
    const navObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-target') === entry.target.id);
          });
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px' });
    sections.forEach(s => navObserver.observe(s));
  });
</script>

</body>
</html>